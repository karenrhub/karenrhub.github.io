<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Spanish Guidebook</title>
<style>
  :root {
    --ink: #1A1209; --paper: #F7F3ED; --gold: #C9A84C;
    --muted: #8A7F72; --border: #DDD5C4; --white: #ffffff;
  }
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  body { background:var(--paper); font-family:Georgia,serif; min-height:100vh; }

/* HEADER */
.header { background:var(–ink); color:var(–paper); padding:20px 16px 0; }
.header-label { font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:var(–gold); margin-bottom:6px; font-family:sans-serif; }
.header-row { display:flex; justify-content:space-between; align-items:flex-start; }
.header-title { font-size:1.5rem; font-weight:bold; }
.header-count { font-size:0.75rem; color:rgba(247,243,237,0.45); font-family:sans-serif; margin-top:4px; }
.btn-add { background:var(–gold); color:var(–ink); border:none; border-radius:3px; padding:8px 14px; font-family:sans-serif; font-size:0.8rem; font-weight:700; cursor:pointer; white-space:nowrap; margin-top:4px; }

/* TABS */
.tabs { display:flex; overflow-x:auto; margin-top:16px; scrollbar-width:none; -ms-overflow-style:none; }
.tabs::-webkit-scrollbar { display:none; }
.tab { background:none; border:none; border-bottom:2px solid transparent; color:rgba(247,243,237,0.38); font-family:sans-serif; font-size:0.72rem; padding:10px 12px; white-space:nowrap; cursor:pointer; transition:all 0.15s; }
.tab.active { color:var(–gold); border-bottom-color:var(–gold); }

/* BODY */
.body { max-width:680px; margin:0 auto; padding:16px 14px 80px; }

/* TOAST */
.toast { background:#EEFAF7; border:1px solid #27AE60; border-radius:4px; padding:10px 14px; margin-bottom:14px; font-family:sans-serif; font-size:0.85rem; color:#27AE60; display:none; }
.toast.show { display:block; }

/* FORM */
.form-box { background:var(–white); border:1px solid var(–border); border-radius:4px; padding:18px; margin-bottom:16px; box-shadow:0 2px 12px rgba(0,0,0,0.06); display:none; }
.form-box.show { display:block; }
.form-label { font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; color:var(–muted); margin-bottom:6px; font-family:sans-serif; }
.form-hint { font-size:0.85rem; color:#6B6058; margin-bottom:12px; line-height:1.6; }
textarea { width:100%; min-height:150px; border:1px solid var(–border); border-radius:3px; padding:10px; font-family:sans-serif; font-size:0.85rem; line-height:1.6; outline:none; background:#FDFAF5; resize:vertical; color:#3A3530; }
.parse-error { color:#C0392B; font-family:sans-serif; font-size:0.82rem; margin-top:8px; display:none; }
.parse-error.show { display:block; }
.preview-box { margin-top:12px; background:var(–paper); border:1px solid var(–border); border-radius:3px; padding:14px; display:none; }
.preview-box.show { display:block; }
.preview-ok { font-size:0.62rem; letter-spacing:0.2em; text-transform:uppercase; color:var(–muted); font-family:sans-serif; margin-bottom:8px; }
.preview-phrase { font-size:1.1rem; font-weight:bold; color:var(–ink); }
.preview-phonetic { font-size:0.82rem; color:var(–gold); font-style:italic; margin-top:2px; }
.preview-context { font-size:0.75rem; color:#AAA4A0; font-family:sans-serif; font-style:italic; margin-top:4px; }
.badge { display:inline-block; color:#fff; font-family:sans-serif; font-size:0.6rem; letter-spacing:0.1em; text-transform:uppercase; padding:2px 8px; border-radius:2px; margin-top:8px; }
.form-btns { display:flex; gap:10px; margin-top:14px; }
.btn-save { background:var(–ink); color:var(–paper); border:none; border-radius:3px; padding:10px 20px; font-family:sans-serif; font-size:0.85rem; font-weight:500; cursor:pointer; }
.btn-save:disabled { background:#ccc; cursor:default; }
.btn-cancel { background:none; border:1px solid var(–border); color:var(–muted); border-radius:3px; padding:10px 14px; font-family:sans-serif; font-size:0.85rem; cursor:pointer; }

/* SEARCH */
.search-wrap { margin-bottom:14px; }
.search-wrap input { width:100%; border:1px solid var(–border); border-radius:3px; padding:10px 14px; font-family:sans-serif; font-size:0.9rem; outline:none; background:var(–white); }

/* EMPTY */
.empty { text-align:center; padding:48px 20px; color:var(–muted); }
.empty-icon { font-size:2.5rem; margin-bottom:12px; }
.empty-title { font-family:sans-serif; font-size:0.95rem; margin-bottom:6px; }
.empty-sub { font-family:sans-serif; font-size:0.82rem; color:#AAA4A0; margin-bottom:20px; line-height:1.6; }
.btn-empty { background:var(–ink); color:var(–paper); border:none; border-radius:3px; padding:10px 20px; font-family:sans-serif; font-size:0.85rem; cursor:pointer; }

/* CARDS */
.card { background:var(–white); border:1px solid var(–border); border-radius:4px; margin-bottom:10px; overflow:hidden; }
.card-top { padding:14px; cursor:pointer; display:flex; justify-content:space-between; align-items:flex-start; gap:10px; }
.card-main { flex:1; }
.card-cat-badge { display:inline-block; color:#fff; font-family:sans-serif; font-size:0.58rem; letter-spacing:0.1em; text-transform:uppercase; padding:2px 7px; border-radius:2px; margin-bottom:6px; }
.card-context { font-size:0.73rem; color:#AAA4A0; font-family:sans-serif; font-style:italic; margin-bottom:4px; }
.card-phrase { font-size:1.15rem; font-weight:bold; color:var(–ink); line-height:1.3; }
.card-phonetic { font-size:0.8rem; color:var(–gold); font-style:italic; margin-top:3px; }
.card-arrow { color:#CCC; font-size:0.8rem; flex-shrink:0; margin-top:4px; }
.card-body { border-top:1px solid #F0EBE3; padding:14px; display:none; }
.card-body.open { display:block; }
.detail-label { font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; color:var(–muted); font-family:sans-serif; margin-bottom:4px; }
.detail-text { font-size:0.9rem; line-height:1.65; color:#3A3530; margin-bottom:12px; }
.detail-formal { font-size:0.88rem; color:#6B6058; font-style:italic; margin-bottom:12px; }
.bonus-box { background:#FFF8E8; border-left:3px solid var(–gold); padding:10px 14px; border-radius:0 3px 3px 0; margin-bottom:12px; }
.bonus-label { font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; color:#B5860A; font-family:sans-serif; margin-bottom:3px; }
.bonus-text { font-size:0.86rem; line-height:1.6; color:#3A3530; }
.btn-remove { background:none; border:1px solid #DDCCC4; color:#C0392B; border-radius:3px; padding:6px 12px; font-family:sans-serif; font-size:0.73rem; cursor:pointer; margin-top:4px; }
</style>

</head>
<body>

<div class="header">
  <div class="header-label">🇪🇸 My Spanish Guidebook · Spain</div>
  <div class="header-row">
    <div>
      <div class="header-title">Speak Like a Local</div>
      <div class="header-count" id="phraseCount">0 phrases saved</div>
    </div>
    <button class="btn-add" onclick="openForm()">+ Add Phrase</button>
  </div>
  <div class="tabs" id="tabs"></div>
</div>

<div class="body">
  <div class="toast" id="toast">Phrase saved! ✓</div>

  <!-- PASTE FORM -->

  <div class="form-box" id="formBox">
    <div class="form-label">Add a phrase</div>
    <div class="form-hint">Copy my full reply from the chat and paste it below — the guidebook reads it automatically 👇</div>
    <textarea id="pasteArea" placeholder="Paste Claude's reply here...&#10;&#10;📋 Context: ...&#10;🇪🇸 Phrase: ...&#10;👂 Say it: ...&#10;💡 Why: ...&#10;📚 Textbook: ...&#10;🌟 Bonus: ...&#10;🏷️ Category: ..." oninput="handlePaste(this.value)"></textarea>
    <div class="parse-error" id="parseError">Couldn't read this — make sure you've copied the full reply including the 🇪🇸 line.</div>
    <div class="preview-box" id="previewBox">
      <div class="preview-ok">Looks good ✓</div>
      <div class="preview-phrase" id="previewPhrase"></div>
      <div class="preview-phonetic" id="previewPhonetic"></div>
      <div class="preview-context" id="previewContext"></div>
      <div id="previewBadge"></div>
    </div>
    <div class="form-btns">
      <button class="btn-save" id="btnSave" onclick="confirmSave()" disabled>Save to guidebook</button>
      <button class="btn-cancel" onclick="closeForm()">Cancel</button>
    </div>
  </div>

  <!-- SEARCH -->

  <div class="search-wrap" id="searchWrap" style="display:none">
    <input type="search" placeholder="Search phrases..." oninput="renderCards()" id="searchInput">
  </div>

  <!-- CARDS -->

  <div id="cards"></div>
</div>

<script>
const CATEGORIES = [
  { id:"all",          label:"All",          emoji:"📖", color:"#1A1209" },
  { id:"Greetings",    label:"Greetings",    emoji:"👋", color:"#C0392B" },
  { id:"Small Talk",   label:"Small Talk",   emoji:"💬", color:"#27AE60" },
  { id:"Food & Drink", label:"Food & Drink", emoji:"🍷", color:"#E67E22" },
  { id:"Directions",   label:"Directions",   emoji:"🗺️", color:"#2980B9" },
  { id:"Transport",    label:"Transport",    emoji:"🚇", color:"#8E44AD" },
  { id:"Shopping",     label:"Shopping",     emoji:"🛍️", color:"#16A085" },
  { id:"Hotel",        label:"Hotel",        emoji:"🏨", color:"#2C3E50" },
  { id:"Socialising",  label:"Socialising",  emoji:"🥂", color:"#D35400" },
  { id:"Slang",        label:"Slang",        emoji:"😎", color:"#7F8C8D" },
  { id:"Emergencies",  label:"Emergencies",  emoji:"🚨", color:"#C0392B" },
];

const CAT_BG = {
  "Greetings":"#FFF0EE","Small Talk":"#F0FFF6","Food & Drink":"#FFF6EE",
  "Directions":"#EEF4FF","Transport":"#F5EEFF","Shopping":"#EEFAF7",
  "Hotel":"#EEEEFF","Socialising":"#FFF3EE","Slang":"#F5F5F5","Emergencies":"#FFF0EE"
};

let phrases = [];
let activeTab = "all";
let preview = null;
let expanded = null;

function load() {
  try { phrases = JSON.parse(localStorage.getItem("es_phrases") || "[]"); } catch { phrases = []; }
  renderTabs(); renderCards();
}

function persist() {
  localStorage.setItem("es_phrases", JSON.stringify(phrases));
}

function catFor(id) { return CATEGORIES.find(c => c.id === id) || CATEGORIES[0]; }
function countFor(id) { return id === "all" ? phrases.length : phrases.filter(p => p.category === id).length; }

function renderTabs() {
  const tabs = document.getElementById("tabs");
  tabs.innerHTML = CATEGORIES
    .filter(c => c.id === "all" || countFor(c.id) > 0)
    .map(c => {
      const n = countFor(c.id);
      return `<button class="tab${activeTab===c.id?" active":""}" onclick="setTab('${c.id}')">${c.emoji} ${c.label}${n>0?" ("+n+")":""}</button>`;
    }).join("");
  document.getElementById("phraseCount").textContent = phrases.length + " phrase" + (phrases.length!==1?"s":"") + " saved";
  document.getElementById("searchWrap").style.display = phrases.length > 3 ? "block" : "none";
}

function setTab(id) { activeTab = id; renderTabs(); renderCards(); }

function renderCards() {
  const q = (document.getElementById("searchInput")?.value || "").toLowerCase();
  const filtered = phrases.filter(p => {
    const matchCat = activeTab === "all" || p.category === activeTab;
    const matchSearch = !q || p.local_phrase?.toLowerCase().includes(q) || p.context?.toLowerCase().includes(q) || p.explanation?.toLowerCase().includes(q);
    return matchCat && matchSearch;
  });

  const container = document.getElementById("cards");

  if (filtered.length === 0) {
    container.innerHTML = `<div class="empty">
      <div class="empty-icon">${phrases.length===0?"📖":"🔍"}</div>
      <div class="empty-title">${phrases.length===0?"Your guidebook is empty":"No phrases found"}</div>
      <div class="empty-sub">${phrases.length===0?"Ask me anything in the chat, then paste my reply here to save it.":"Try a different search or category."}</div>
      ${phrases.length===0?'<button class="btn-empty" onclick="openForm()">+ Add your first phrase</button>':""}
    </div>`;
    return;
  }

  container.innerHTML = filtered.map(p => {
    const cat = catFor(p.category);
    const bg = CAT_BG[p.category] || "#F7F3ED";
    const isOpen = expanded === p.id;
    return `
    <div class="card" style="border-left:3px solid ${cat.color}">
      <div class="card-top" onclick="toggle(${p.id})">
        <div class="card-main">
          <span class="card-cat-badge" style="background:${cat.color}">${cat.emoji} ${p.category}</span>
          ${p.context?`<div class="card-context">"${p.context}"</div>`:""}
          <div class="card-phrase">${p.local_phrase}</div>
          ${p.phonetic?`<div class="card-phonetic">/ ${p.phonetic} /</div>`:""}
        </div>
        <div class="card-arrow">${isOpen?"▲":"▼"}</div>
      </div>
      <div class="card-body${isOpen?" open":""}" style="background:${bg}">
        ${p.explanation?`<div class="detail-label">Why locals say it</div><div class="detail-text">${p.explanation}</div>`:""}
        ${p.formal_version?`<div class="detail-label">Textbook version</div><div class="detail-formal">${p.formal_version}</div>`:""}
        ${p.bonus_tip?`<div class="bonus-box"><div class="bonus-label">💡 Bonus tip</div><div class="bonus-text">${p.bonus_tip}</div></div>`:""}
        <button class="btn-remove" onclick="deletePhrase(${p.id})">Remove phrase</button>
      </div>
    </div>`;
  }).join("");
}

function toggle(id) {
  expanded = expanded === id ? null : id;
  renderCards();
}

function deletePhrase(id) {
  phrases = phrases.filter(p => p.id !== id);
  if (expanded === id) expanded = null;
  persist(); renderTabs(); renderCards();
}

// FORM
function openForm() {
  document.getElementById("formBox").classList.add("show");
  document.getElementById("pasteArea").value = "";
  document.getElementById("parseError").classList.remove("show");
  document.getElementById("previewBox").classList.remove("show");
  document.getElementById("btnSave").disabled = true;
  preview = null;
}

function closeForm() {
  document.getElementById("formBox").classList.remove("show");
  preview = null;
}

function getLine(text, emoji) {
  const re = new RegExp(emoji + "[^:\\n]*:\\s*(.+)", "i");
  const m = text.match(re);
  return m ? m[1].replace(/\*\*/g,"").trim() : "";
}

function handlePaste(text) {
  document.getElementById("parseError").classList.remove("show");
  document.getElementById("previewBox").classList.remove("show");
  document.getElementById("btnSave").disabled = true;
  preview = null;
  if (!text.trim()) return;

  const local_phrase   = getLine(text, "🇪🇸");
  const phonetic       = getLine(text, "👂").replace(/^\/\s*/,"").replace(/\s*\/$/,"");
  const context        = getLine(text, "📋");
  const explanation    = getLine(text, "💡");
  const formal_version = getLine(text, "📚");
  const bonus_tip      = getLine(text, "🌟");
  const catLine        = getLine(text, "🏷️");
  const catObj         = CATEGORIES.find(c => c.id !== "all" && catLine.toLowerCase().includes(c.label.toLowerCase())) || CATEGORIES.find(c=>c.id==="Small Talk");
  const category       = catObj.id;

  if (!local_phrase) { document.getElementById("parseError").classList.add("show"); return; }

  preview = { local_phrase, phonetic, context, explanation, formal_version, bonus_tip, category };

  document.getElementById("previewPhrase").textContent = local_phrase;
  document.getElementById("previewPhonetic").textContent = phonetic ? "/ "+phonetic+" /" : "";
  document.getElementById("previewContext").textContent = context ? '"'+context+'"' : "";
  document.getElementById("previewBadge").innerHTML = `<span class="badge" style="background:${catObj.color}">${catObj.emoji} ${category}</span>`;
  document.getElementById("previewBox").classList.add("show");
  document.getElementById("btnSave").disabled = false;
}

function confirmSave() {
  if (!preview) return;
  phrases.unshift({ ...preview, id: Date.now() });
  persist();
  closeForm();
  renderTabs(); renderCards();
  const toast = document.getElementById("toast");
  toast.classList.add("show");
  setTimeout(() => toast.classList.remove("show"), 2500);
}

load();
</script>

</body>
</html>
